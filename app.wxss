page {
  background-color: #f5f7fa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  padding-top: env(safe-area-inset-top);
  padding-bottom: env(safe-area-inset-bottom);
  min-height: 100vh;
}

.container {
  padding: 20rpx 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #007AFF;
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  margin-top: 20rpx;
}

.btn.disabled {
  background: #ccc;
}

input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.picker-container {
  margin-bottom: 20rpx;
}

.picker-label {
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.picker-input {
  height: 88rpx;
  line-height: 88rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}